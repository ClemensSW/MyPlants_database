# Dependencies
node_modules/
package-lock.json

# Environment
.env
.env.local

# Intermediate data files
data/intermediate/*
!data/intermediate/.gitkeep

# Large data files (zu groß für Git)
data/output/*.ndjson
data/output/*.json
archive/*.ndjson
tools/*.ndjson

# Test data files
data/intermediate/*_test.*
data/output/*_test.*

# Logs
*.log
failed_keys.txt

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
temp/

# Hints pipeline: local work-in-progress files
# pending/ holds candidates awaiting review — don't commit
# approved/ and queue.json ARE committed (they are the reviewed result)
data/hints/pending/
